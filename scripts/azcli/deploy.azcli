# Login to Azure and deploy the bicep infrastructure
az login --use-device-code
az account list --output table
az account list --query "[].{Name:name, ID:id}" -o table
az account set --subscription 
az account list --all --output table
az account show --query 'name' -o table
az account show --query "{Name:name, ID:id}" -o table
az account show --query "{ID:id, Name:name}" -o table
az account clear

../scripts/remove-all.sh subs=$(az account list --query "[].id" -o tsv | paste -sd "," -)

sub_id=$(az account show --query 'id' -o tsv); echo $sub_id
#
# List all resource groups in the subscription
az account list --query "[].id" -o table

for sub in $(az account list --query "[].id" -o tsv); do
  echo "Resource Groups in subscription: $sub"
  az group list --subscription $sub --output table
  echo ""
done

az group list --output table
az group create --location westus2 --resource-group acrRG -o table
az group delete --name appRG --no-wait --yes
rg=$(az group list --query "[?name=='xelademo'].name" --output tsv); echo $rg
rg=$(az group list --query "[].name" --output tsv); echo $rg

# Generate self-signed cert and the webapp key and crt file
openssl req -x509 -nodes -days 365 -newkey rsa:2048 -keyout webapp.key -out webapp.crt -subj "/CN=webapp.xelatech.net" -addext "subjectAltName=DNS:webapp.xelatech.net"

# Convert cert/key into PFX (for secure binding in WAF/App Gateway) 
openssl pkcs12 -export -out webapp.pfx -inkey webapp.key -in webapp.crt

#  upload to keyvault
az keyvault certificate import --vault-name xelavault5nwf --name xelaSslCert --file webapp.pfx --password "AnotherDayInParadise"

# Retrieve the SecretId for your Bicep input:
sslCertSecretId=$(az keyvault secret show --vault-name xelavault5nwf --name xelaSslCert --query 'id' -o tsv | sed 's|/[0-9a-f-]*$||'); echo $sslCertSecretId

# ACR and KV deployment - set up adminPassword
az deployment sub create --template-file subsmain.bicep --parameters  accessKey=$accessKey --what-if
natPublicIP=$(curl -4 -s ifconfig.me)

accessKey=$(python ../quickstart/pwdgen.py); echo $accessKey > pwd.txt
az keyvault secret set --vault-name xelavault5nwf --name accesKey --description "Access for VMs, SQL, vpn" --value $(python ../quickstart/pwdgen.py)
az keyvault secret list --vault-name xelavault5nwf --query "[].{Name:name, ID:id}" -o table
accessKey=$(az keyvault secret show --vault-name xelavault5nwf --name accesKey --query "value" -o tsv); echo $accessKey

#  upload to keyvault
az keyvault certificate import --vault-name xelavault5nwf --name xelaSslCert --file webapp.pfx --password "AnotherDayInParadise"

# call out the ACR username, password, and sslCertSecretId and accessKeys
ACR_USERNAME=$(az acr credential show --name xelambpi --query username -o tsv);echo $ACR_USERNAME
ACR_PASSWORD=$(az acr credential show --name xelambpi --query 'passwords[0].value' -o tsv);echo $ACR_PASSWORD
sslCertSecretId=$(az keyvault secret show --vault-name xelavault5nwf --name xelaSslCert --query 'id' -o tsv | sed 's|/[0-9a-f-]*$||'); echo $sslCertSecretId
accessKey=$(az keyvault secret show --vault-name xelavault5nwf --name accesKey --query "value" -o tsv); echo $accessKey

# Validate the test bicep (dry run)
az deployment sub create --template-file main.bicep --parameters sshPublicKey="$(cat ~/.ssh/id_rsa.pub)" publicIP=$(curl -4 -s ifconfig.me) acrUsername=$ACR_USERNAME acrPassword=$ACR_PASSWORD sslCertSecretId=$sslCertSecretId accessKey=$accessKey 
--what-if

az deployment sub validate --template-file main.bicep --parameters sshPublicKey="$(cat ~/.ssh/id_rsa.pub)" publicIP=$(curl -4 -s ifconfig.me) acrUsername=$ACR_USERNAME acrPassword=$ACR_PASSWORD sslCertSecretId=$sslCertSecretId accessKey=$accessKey 

# check app service plan status
az webapp log tail --name xeladhis --resource-group acrRG
az webapp show --name xeladhis --resource-group acrRG --query identity
# 3. Upload to Azure Key Vault
az keyvault secret set --vault-name keyVaultskcw --name xelaSslCert --file xelaSslCert.pfx --encoding base64
#get full keyvaultsecretId
az keyvault secret list --vault-name keyVaultskcw --query "[].{Name:name, ID:id}" -o table
sslCertSecretId=$(az keyvault secret list-versions --vault-name keyVaultskcw --name xelaSslCert --query "[0].id" -o tsv)
echo $sslCertSecretId

az deployment group create --resource-group appRG --template-file appservice.bicep --parameters publicIP="97.94.98.13"

az deployment sub create \
  --location westus2 \  # You MUST specify a location for subscription-level deployments
  --template-file main.bicep \
  --parameters \
    sshPublicKey="$(cat ~/.ssh/id_rsa.pub)" \
    sharedKey="$(openssl rand -base64 32)" \
    publicIP="$(curl -4 -s ifconfig.me)" \
  --mode Complete
# what deployment was successful  
az deployment sub list -o table
az deployment sub show --name main -o table
az deployment sub list --query "[].{Name:name, Timestamp:properties.timestamp, Status:properties.provisioningState}" --output table
az deployment sub wait --name main --created


../remove-all.sh

# Deploy ACR build
# Set environment variables for ACR and managed identity details
RG=rg=$(az group list --query "[?name=='acrRG'].name" --output tsv);echo $RG
ACR_NAME=$(az acr list --query "[].name" --output tsv); echo $ACR_NAME
ACR_LOGIN_SERVER=$(az acr list --query "[].loginServer" --output tsv); echo $ACR_LOGIN_SERVER
az acr login --name $ACR_NAME
az acr repository list --name acrRG --output table
docker buildx build --platform linux/amd64 -t $ACR_LOGIN_SERVER/xelatech-webapp:latest --no-cache --push .
# Build and push the Docker image to ACR
az acr build --registry $ACR_NAME --image $ACR_LOGIN_SERVER/xelatech-webapp:latest --file Dockerfile --platform linux/amd64 .


# Test DNS resolution to private link
nslookup xelaLogsezrz.ods.opinsights.azure.com
