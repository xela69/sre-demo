az vm list-skus --location westus2 --size Standard_E2ads_v5 --output table

az vm list-skus --location westus2 --resource-type "virtualMachines" --query "[?capabilities[?name=='vCPUs' && value=='4'] && capabilities[?name=='MemoryGB' && value=='16']].{Name:name, vCPUs:[?capabilities[?name=='vCPUs']].value | [0], MemoryGB:[?capabilities[?name=='MemoryGB']].value | [0], Restrictions:restrictions}" --output json | egrep -v westus2

# generate ssl cert for app service
# 1. Generate private key and certificate
openssl req -x509 -nodes -days 365 -newkey rsa:2048 -keyout xela.key -out xela.crt -subj "/CN=app.xelatech.net"

# 2. Convert to .pfx
openssl pkcs12 -export -out xelaSslCert.pfx -inkey xela.key -in xela.crt
# 3. Upload to Azure Key Vault
az keyvault secret set --vault-name xelavault --name xelaSslCert --file xelaSslCert.pfx --encoding base64
#get full keyvaultsecretId
az keyvault secret list --vault-name xelavault --query "[].{Name:name, ID:id}" -o table
az keyvault secret list-versions --vault-name xelavault --name xelaSslCert --query "[0].id" -o tsv


az network application-gateway show-backend-health --resource-group securityRG --name xelawafgw --query "backendAddressPools[*].backendHttpSettingsCollection[*].servers[*].health" --output table


az rest --method GET --uri "https://graph.microsoft.com/v1.0/servicePrincipals?\$filter=appId eq 'abfa0a7c-a6b6-4736-8310-5855508787cd'" --query "value[0].id" -o tsv

# Use this Bicep snippet for Microsoft.Web SP (hardcoded for now): 164241dd-bd5a-4b9a-9d38-e987795b357e



# Generate new key and CSR with correct EKU
openssl req -new -newkey rsa:2048 -nodes -keyout webapp.key -out webapp.csr -subj "/CN=webapp.xelatech.net"

# Self-sign the cert with the required EKU
openssl x509 -req -days 365 -in webapp.csr -signkey webapp.key -out webapp.crt -extfile <(printf "extendedKeyUsage=serverAuth")

# Kill Vnet Peering and recreate

az network vnet peering list --resource-group networkRG --vnet-name HubVnet --output table

az network vnet peering delete --resource-group networkRG --vnet-name HubVnet --name HubVnet-To-AppsVnet
az network vnet peering delete --resource-group networkRG --vnet-name appVnet --name AppsVnet-To-HubVnetPeering

az network vnet peering create --name HubVnet-To-AppsVnetPeering --resource-group networkRG --vnet-name HubVnet --remote-vnet appVnet --allow-vnet-access

az network vnet peering create --name AppsVnet-To-HubVnetPeering --resource-group networkRG --vnet-name appVnet --remote-vnet HubVnet --allow-vnet-access


az webapp show --name xelawebgkqf --resource-group appRG --query customDomainVerificationId --output tsv
# use this verification token to create CNAME record in DNS -- 3BE8C67D301CE0B9B60795A106F13746A92425CD7758826EABA6D518E567D125

az network vpn-connection show --resource-group networkRG --name XelaVPNConnection --output table

az network vpn-connection list-ike-sas --resource-group networkRG --name XelaVPNConnection --output table
az network vpn-gateway connection list --resource-group networkRG --gateway-name GatewaySubnet --output table
az network vnet-gateway disconnect-vpn-connections --resource-group networkRG --gateway-name xelavpnrpxq --output table

# If you ever want to assign a route table after the subnet already exists, you can use a separate resource like: just reference the existing VNet and subnet, and then assign the route table to the subnet.
resource vnet 'Microsoft.Network/virtualNetworks@2024-07-01' existing = {
  name: 'vnetName'
  scope: resourceGroup('resourceGroupName')
}
resource routeTable 'Microsoft.Network/routeTables@2024-07-01' existing = {
  name: 'routeTableName'
  scope: resourceGroup('resourceGroupName')
}
# Assign the route table to the existing subnet
resource subnetWithRouteTable 'Microsoft.Network/virtualNetworks/subnets@2024-07-01' = {
  name: 'subnetName'
  parent: vnet
  properties: {
    ...
    routeTable: { id: routeTable.id }
  }
}
# Create resource groups for each subscription
for sub in <subid-1> <subid-2> <subid-3>; do
  az account set --subscription $sub
  az group create --name CPS-NCUS-Apps --location eastus
  az group create --name CPS-NCUS-Data --location westus
  az group create --name CPS-NCUS-Infra --location centralus
done

