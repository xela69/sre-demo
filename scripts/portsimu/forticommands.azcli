# From your Azure CLI shell, verify BGP is truly on and the peer is correct:
# 1) VNet gateway BGP IPs (one or two; add both as neighbors on Forti if two are returned)
RG=networkRG
GW=xelavpni5id
CONN=XelaVPNConnection
        # e.g., XelaVPNConnection
LNG=xelalocalgw
az network vnet-gateway show -g $RG -n $GW --query "bgpSettings.bgpPeeringAddresses[].defaultBgpIpAddresses[]"

# 2) Local Network Gateway’s BGP (your side)
az network local-gateway show -g $RG -n $LNG --query "{asn:bgpSettings.asn, peer:bgpSettings.bgpPeeringAddress}"

# 3) Connection must have BGP enabled
az network vpn-connection show -g $RG -n $CONN --query "properties.enableBgp"
# connection BGP toggle
az network vpn-connection show -g $RG -n $CONN --query "{name:name, enableBgp:properties.enableBgp, status:properties.connectionStatus}"

az network vpn-connection show -g $RG -n $CONN --query "{status:properties.connectionStatus, enableBgp:properties.enableBgp}" -o table
az network vnet-gateway show -g $RG -n $GW --query "bgpSettings.bgpPeeringAddresses[].defaultBgpIpAddresses[]"
# if enableBgp is not true:
az network vpn-connection update -g $RG -n $CONN --enable-bgp true

execute router clear bgp all
diagnose sniffer packet azure-a-p1 "host 10.50.3.30 and port 179" 4 10
get router info bgp summary

# remove all bgp settings:
config router bgp
  config neighbor
    delete 10.50.3.30
  end
  config network
    delete 10
    delete 20
    delete 30
    delete 40
  end
end

config router route-map
  delete "RM-TO-AZURE"
  delete "RM-FROM-AZURE"
end

config router access-list
  delete "TO-AZURE"
  delete "FROM-AZURE"
end

# Flush any remaining BGP state
execute router clear bgp all

