az network public-ip show --ids /subscriptions/155abeb8-c0a9-4927-a455-986a03026829/resourceGroups/NetworkRG/providers/Microsoft.Network/publicIPAddresses/xelavpnpipejx3 --query "{name:name, ip:ipAddress}" -o table

az network local-gateway show -g $RG -n $LNG --query "{pip:properties.gatewayIpAddress, bgpPeer:properties.bgpSettings.bgpPeeringAddress}"

#1) (Optional) tidy destination objects for Azure VNets
config firewall address
  edit "AZ-10.50.0.0_20" 
    set subnet 10.50.0.0 255.255.240.0 
  next
  edit "AZ-10.51.0.0_20" 
    set subnet 10.51.0.0 255.255.240.0 
  next
  edit "AZ-10.52.0.0_20" 
    set subnet 10.52.0.0 255.255.240.0 
  next
  edit "AZ-10.53.0.0_20" 
    set subnet 10.53.0.0 255.255.240.0 
  next
  edit "AZ-10.54.0.0_20" 
    set subnet 10.54.0.0 255.255.240.0 
  next
end
config firewall addrgrp
  edit "AZURE-VNETS"
    set member "AZ-10.50.0.0_20" "AZ-10.51.0.0_20" "AZ-10.52.0.0_20" "AZ-10.53.0.0_20" "AZ-10.54.0.0_20"
  next
end

# 2) Forward policies (on-prem → Azure, no NAT)
config firewall policy
  # Wi-Fi -> Azure
  edit 3
    set name "WiFi->Azure"
    set srcintf "wifi"
    set dstintf "azure-a-p1"
    set srcaddr "WIFI-10.2.1.0_24"
    set dstaddr "AZURE-VNETS"      
    set action accept
    set schedule "always"
    set service "ALL"
    set nat disable
  next

  # internal2 -> Azure
  edit 4
    set name "Internal2->Azure"
    set srcintf "internal2"
    set dstintf "azure-a-p1"
    set srcaddr "LAN2-10.6.1.0_24"
    set dstaddr "AZURE-VNETS"      # or "all"
    set action accept
    set schedule "always"
    set service "ALL"
    set nat disable
  next

  # internal3 -> Azure
  edit 5
    unset status                   
    set name "Internal3->Azure"
    set srcintf "internal3"
    set dstintf "azure-a-p1"
    set srcaddr "LAN3-172.16.110.0_24"
    set dstaddr "AZURE-VNETS"     
    set action accept
    set schedule "always"
    set service "ALL"
    set nat disable
  next

  # internal4 -> Azure
  edit 6
    unset status
    set name "Internal4->Azure"
    set srcintf "internal4"
    set dstintf "azure-a-p1"
    set srcaddr "LAN4-172.17.110.0_24"
    set dstaddr "AZURE-VNETS"      # or "all"
    set action accept
    set schedule "always"
    set service "ALL"
    set nat disable
  next
end
#3) Return policies (Azure-initiated → on-prem, no NAT)
config firewall policy
  # Azure -> Wi-Fi
  edit 7
    unset status                   
    set name "Azure->WiFi"
    set srcintf "azure-a-p1"
    set dstintf "wifi"
    set srcaddr "AZURE-VNETS"      
    set dstaddr "WIFI-10.2.1.0_24"
    set action accept
    set schedule "always"
    set service "ALL"
    set nat disable
  next

  # Azure -> internal2
  edit 8
    unset status
    set name "Azure->Internal2"
    set srcintf "azure-a-p1"
    set dstintf "internal2"
    set srcaddr "AZURE-VNETS"      
    set dstaddr "LAN2-10.6.1.0_24"
    set action accept
    set schedule "always"
    set service "ALL"
    set nat disable
  next

  # Azure -> internal3
  edit 9
    unset status
    set name "Azure->Internal3"
    set srcintf "azure-a-p1"
    set dstintf "internal3"
    set srcaddr "AZURE-VNETS"
    set dstaddr "LAN3-172.16.110.0_24"
    set action accept
    set schedule "always"
    set service "ALL"
    set nat disable
  next

  # Azure -> internal4
  edit 10
    unset status
    set name "Azure->Internal4"
    set srcintf "azure-a-p1"
    set dstintf "internal4"
    set srcaddr "AZURE-VNETS"
    set dstaddr "LAN4-172.17.110.0_24"
    set action accept
    set schedule "always"
    set service "ALL"
    set nat disable
  next
end

#4) Order matters
config firewall policy
  move 3  top
  move 4  after 3
  move 5  after 4
  move 6  after 5
  move 7  after 6
  move 8  after 7
  move 9  after 8
  move 10 after 9
end
