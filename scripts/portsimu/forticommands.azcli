# Fix: explicitly allow BGP to the Forti on the IPsec interface
show firewall local-in-policy 1


# 1) Address object for Azure BGP IP
config firewall address
  edit "AZURE-BGP-IP"
    set subnet 10.50.3.30 255.255.255.255
  next
end

# 2) Service object for BGP (exists on most boxes; create if missing)
show firewall service custom BGP
# if missing:
config firewall service custom
  edit "BGP"
    set tcp-portrange 179
  next
end

# 3) Allow BGP from Azure over the tunnel to the Forti itself

# 5) Nudge the session
execute router clear bgp neighbor 10.50.3.30 soft in
execute router clear bgp neighbor 10.50.3.30 soft out
# Clear *all* BGP sessions (works on all recent FortiOS)
execute router clear bgp all
# or per neighbor on many builds:
execute router clear bgp 10.50.3.30  
# You should now see SYN, SYN-ACK, ACK
diagnose sniffer packet azure-a-p1 "host 10.50.3.30 and port 179" 4 20

get router info bgp summary
get router info bgp neighbors 10.50.3.30
get router info bgp network

# 1) Allow BGP to the Forti on the IPsec interface --(optional) check if local-in is being enforced
show system settings | grep firewall-local-in-policy

# If you see 'set firewall-local-in-policy enable', good. If not, you can enable it:
# config system settings
#   set firewall-local-in-policy enable
# end

# Address object for Azure’s BGP IP
config firewall address
  edit "AZURE-BGP-IP"
    set subnet 10.50.3.30 255.255.255.255
  next
end

# BGP service (exists on most boxes; create if missing)
config firewall service custom
  edit "BGP"
    set tcp-portrange 179
  next
end

# Local-in policy: allow BGP from Azure over the tunnel to *this Forti*
config firewall local-in-policy 
  edit 1
    set intf "azure-a-p1"
    set srcaddr "all"       #"AZURE-BGP-IP"
    set dstaddr "all"
    set service "all"           #"BGP"
    set schedule "always"
    set action accept
  next
end

#  comes from 10.50.3.30:179 to Forti’s ephemeral port (dst ≠ 179) -- return on highports
config firewall service custom 
  edit "TCP-HIGH"
    set tcp-portrange 1024-65535
  next
end
config firewall local-in-policy
  edit 2
    set intf "azure-a-p1"
    set srcaddr "all"       #"AZURE-BGP-IP"
    set dstaddr "all"
    set service "TCP-HIGH"
    set schedule "always"   
    set action accept
  next
end
# expect: set firewall-local-in-policy enable|disable
show system settings | grep firewall-local-in-policy 
show firewall local-in-policy 1 
show firewall service custom BGP 

