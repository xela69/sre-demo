# 1) IPsec tunnel interface (/30 + remote-ip)
#PSK -- BU71Rz8Ra@J*nnOyA9QR

config system interface
  edit "azure-a-p1"
    set ip 169.254.21.2/32
    set remote-ip 169.254.21.1/32
    set allowaccess ping
  next
end

# 2) IPsec P1/P2 (PSK + selectors + NAT-T)

# Phase1 (IKEv2) — must match Azure: AES256-SHA256, DHGroup14, IKEv2, DPD 45s
config vpn ipsec phase1-interface
  edit "azure-a-p1"
    set remote-gw 20.83.81.69         # Azure VPN GW public IP (updated Apr 2026)
    set ike-version 2
    set net-device enable
    set nattraversal enable
    set dpd on-idle
    set dpd-retryinterval 45           # matches Azure dpdTimeoutSeconds: 45
    set psksecret BU71Rz8Ra@J*nnOyA9QR
    set proposal aes256-sha256         # matches Azure ikeEncryption: AES256, ikeIntegrity: SHA256
    set dhgrp 14                       # matches Azure dhGroup: DHGroup14
  next
end

# Phase2 (IPsec ESP) — FIXED: must match Azure customIPSecPolicy exactly
# Azure: ipsecEncryption: GCMAES256, ipsecIntegrity: GCMAES256 (combined GCM — no separate HMAC)
# Azure: pfsGroup: None, saLifeTimeSeconds: 27000
config vpn ipsec phase2-interface
  edit "azure-a-p2"
    set phase1name "azure-a-p1"
    set proposal aes256gcm             # GCMAES256 combined mode — was aes256-sha256 (WRONG)
    set pfs disable                    # matches Azure pfsGroup: None  — was pfs enable (WRONG)
    set keylifeseconds 27000           # matches Azure saLifeTimeSeconds: 27000 — was 3600 (WRONG)
    set src-subnet 0.0.0.0 0.0.0.0
    set dst-subnet 0.0.0.0 0.0.0.0
  next
end
# Clear any stale SAs and restart
diagnose vpn ike gateway flush
diagnose vpn ike gateway clear name azure-a-p1
diagnose vpn ike restart

#Actually originate the three on-prem /24s
config router bgp
  config network
    edit 10 
      set prefix 10.6.1.0 255.255.255.0     
    next
    edit 20
      set prefix 172.16.110.0 255.255.255.0
    next
    edit 30
      set prefix 172.17.110.0 255.255.255.0
    next
    # Optional: add 10.2.1.0/24 only if FortiWiFi clients must be reachable from Azure
    edit 40
      set prefix 10.2.1.0 255.255.255.0
    next
  show
  end
  config redistribute "connected" 
    set status disable 
    end
  config redistribute "static"    
    set status disable 
  end
end
# 5) Make sure the neighbor is set for eBGP over a tunnel
config router bgp
  set as 65010
  config neighbor
    edit 10.50.3.30
      set remote-as 65515
      set update-source "azure-a-p1"
      set ebgp-enforce-multihop enable
    next
  end
end

# 6) Clear BGP sessions with the correct syntax
execute router clear bgp all

# Bring-up / verify

# IPsec
get vpn ipsec tunnel summary
diagnose vpn ike gateway list

# BGP
get router info bgp summary
get router info bgp neighbors 10.50.3.30
get router info bgp network  

# Routing
show router bgp 
show router static

diagnose debug reset
diagnose debug application ike -1
diagnose debug enable
# wait 30–60s
diagnose debug disable
# 2) Clear SAs and restart IKE
diagnose vpn ike gateway clear name azure-a-p1
diagnose vpn ike restart

show firewall policy | egrep -i "srcintf" -e "dstintf" -e "name" -e "status" -e "nat"
show firewall policy 3    

# On Azure (after IPsec comes up): You should see exactly: 10.6.1.0/24, 172.16.110.0/24, 172.17.110.0/24 (and Wi-Fi /24 only if you chose to advertise it).
RG=networkRG
GW=xelavpni5id
CONN=XelaVPNConnection
        # e.g., XelaVPNConnection
LNG=xelalocalgw

az network vnet-gateway list-learned-routes -g $RG -n $GW -o table

az network vnet-gateway list-learned-routes -g $RG -n $GW -o table # Learned routes (what Azure sees from Forti)

# Local Network Gateway (Forti side object)
az network local-gateway show -g $RG -n $LNG --query "{pip:properties.gatewayIpAddress, asn:properties.bgpSettings.asn, peerIp:properties.bgpSettings.bgpPeeringAddress,addressSpace:properties.localNetworkAddressSpace.addressPrefixes}" -o json 

# Connection status / IPsec policy
az network vpn-connection show -g $RG -n $CONN --query "{status:properties.connectionStatus, enableBgp:properties.enableBgp, ipsec:properties.ipsecPolicies}" -o json

#VPN gateway: BGP + PIPs
az network vnet-gateway show -g $RG -n $GW --query "{sku:sku.name, enableBgp:properties.enableBgp, asn:properties.bgpSettings.asn,peerIps:properties.bgpSettings.bgpPeeringAddresses[].defaultBgpIpAddresses,ipConfigs:properties.ipConfigurations[].publicIpAddress.id}" -o json

# Resolve attached public IP(s)
for id in $(az network vnet-gateway show -g $RG -n $GW --query "ipConfigurations[].publicIpAddress.id" -o tsv); do
  az network public-ip show --ids $id --query "{name:name, ip:ipAddress}" -o table
done

# on fortigate -- If IKE still sticks at “connecting”, we’ll turn on debug:
diagnose debug enable
diagnose debug console timestamp enable
diagnose debug application ike -1
# try to bring P1 up, then:
diagnose debug disable

#A) Pin a host route to Azure’s BGP IP through the tunnel + enable multihop
# send packets for 10.50.3.30 into the IPsec tunnel
config router static
  edit 200
    set dst 10.50.3.30 255.255.255.255
    set device "azure-a-p1"
  next
end

# neighbor settings
config router bgp
  config neighbor
    edit 10.50.3.30
      set update-source "azure-a-p1"
      unset ebgp-enforce-multihop    # we dont need for BGP --set ebgp-enforce-multihop enable 
      set route-map-out "RM-TO-AZURE"
      set route-map-in  "RM-FROM-AZURE"
    next
  end
end

